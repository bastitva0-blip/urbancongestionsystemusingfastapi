# Copy to .env and fill in values

# Database
POSTGRES_USER=congestion
POSTGRES_PASSWORD=congestion_secret
POSTGRES_DB=congestion_db
DATABASE_URL=postgresql+asyncpg://congestion:congestion_secret@localhost:5432/congestion_db

# API Security
# Generate with: python -c "import hashlib, secrets; k=secrets.token_hex(32); print('Key:', k); print('Hash:', hashlib.sha256(k.encode()).hexdigest())"
API_KEY_HASH=your_sha256_hashed_api_key_here

# Rate limiting (slowapi format)
RATE_LIMIT=100/minute

# Model
MODEL_PATH=./ml_pipeline/models/congestion_model.pkl

# Logging
LOG_LEVEL=INFO

# Environment
ENV=development
